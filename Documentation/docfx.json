{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../",
          "files": ["TextFx.csproj", "TextFx.Editor.csproj"]
        }
      ],
      "output": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**/*.{md,yml}"],
        "exclude": ["_site/**"]
      }
    ],
    "resource": [
      {
        "files": ["assets/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern", "templates/custom"],
    "postProcessors": ["ExtractSearchIndex"],
    "globalMetadata": {
      "_appName": "TextFx",
      "_appFaviconPath": "assets/favicon.ico",
      "_enableSearch": true,
      "_appFooter": "TextFx - Freedee",
      "_disableContribution": true,
      "_disableNextArticle": true,
      "pdf": false
    }
  }
}
